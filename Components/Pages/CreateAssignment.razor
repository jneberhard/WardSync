@page "/assignments/create"
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin,Leader")]
@inject WardSyncService Service
@inject NavigationManager Navigation

<h1>Create Assignment</h1>

<EditForm Model="assignmentForm"
        OnValidSubmit="SaveAssignment"
        FormName="CreateAssignmentForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-grid">
        <InputText @bind-Value="assignmentForm.Title" placeholder="Assignment Title" />
        <InputText @bind-Value="assignmentForm.AssignedLeader" placeholder="Assigned Leader" />
        <InputText @bind-Value="assignmentForm.Organization" placeholder="Organization" />
        <InputDate @bind-Value="assignmentForm.DueDate" />

        <InputSelect @bind-Value="assignmentForm.Priority">
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
        </InputSelect>

        <InputSelect @bind-Value="assignmentForm.Status">
            <option value="Open">Open</option>
            <option value="In Progress">In Progress</option>
            <option value="Completed">Completed</option>
        </InputSelect>
    </div>

    <InputTextArea @bind-Value="assignmentForm.Description" placeholder="Description" />
    <InputTextArea @bind-Value="assignmentForm.Notes" placeholder="Notes" />

    <div class="date-section">
        <label class="form-label">Completion Date</label>
        <InputDate @bind-Value="assignmentForm.CompletionDate" />
    </div>

    <div class="button-row">
        <button class="btn-primary" type="submit">Create Assignment</button>
        <a class="btn-secondary" href="/assignments">Cancel</a>
    </div>
</EditForm>

@code {
    private AssignmentItem assignmentForm = new()
    {
        DueDate = DateTime.Today.AddDays(7),
        Priority = "Medium",
        Status = "Open"
    };

    private async Task SaveAssignment()
    {
        await Service.AddAssignmentAsync(assignmentForm);
        Navigation.NavigateTo("/assignments");
    }
}