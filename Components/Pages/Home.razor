@page "/"
@rendermode InteractiveServer
@inject WardSyncService Service

<PageTitle>WardSync</PageTitle>

<div class="home-page">
    <section class="home-hero" aria-labelledby="home-title">
        <img src="/images/WardSync_picture.webp"
            alt="Latter-day Saint meetinghouse with red brick, white steeple, lawn, and blue sky"
            class="hero-meetinghouse-image" />

        <div class="home-hero-overlay">
            <div class="home-hero-text">
                <p class="home-kicker">Ward and Branch Leadership Workspace</p>
                <h1 id="home-title">WardSync</h1>
                <p class="home-tagline">Organize callings, assignments, and follow-up in one place.</p>
                <p class="home-summary">
                    WardSync helps ward and branch leaders track callings, assignments, and follow-up in one place.
                </p>

                <AuthorizeView Context="homeAuth">
                    <Authorized>
                        <nav class="home-actions" aria-label="Primary home page links">
                            <AuthorizeView Roles="Admin" Context="adminAuth">
                                <Authorized>
                                    <a class="home-button home-button-primary" href="/callings">Callings</a>
                                    <a class="home-button" href="/dashboard">Dashboard</a>
                                </Authorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="Admin,Leader" Context="leaderAuth">
                                <Authorized>
                                    <a class="home-button" href="/assignments">Assignments</a>
                                    <a class="home-button" href="/followups">Follow-Up</a>
                                </Authorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="Admin,Leader,Viewer" Context="viewerAuth">
                                <Authorized>
                                    <a class="home-button" href="/members">Members</a>
                                </Authorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="Admin" Context="reportAuth">
                                <Authorized>
                                    <a class="home-button" href="/reports">Reports</a>
                                </Authorized>
                            </AuthorizeView>

                            <form class="home-logout-form" action="Account/Logout" method="post">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="" />
                                <button type="submit" class="home-button home-button-login">Log Out</button>
                            </form>
                        </nav>
                    </Authorized>
                    <NotAuthorized>
                        <nav class="home-actions" aria-label="Primary home page links">
                            <a class="home-button home-button-primary" href="/Account/Login">Login</a>
                            <a class="home-button" href="/Account/Register">Register</a>
                        </nav>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </section>

    <div class="hero-stat-grid" aria-label="WardSync quick benefits">
        <article class="hero-stat-card">
            <span class="hero-stat-icon" aria-hidden="true">1</span>
            <h2>Track open needs</h2>
            <p>Keep service needs and assignments visible.</p>
        </article>

        <article class="hero-stat-card">
            <span class="hero-stat-icon" aria-hidden="true">2</span>
            <h2>Review follow-up</h2>
            <p>See what still needs attention.</p>
        </article>

        <article class="hero-stat-card">
            <span class="hero-stat-icon" aria-hidden="true">3</span>
            <h2>Prepare for council</h2>
            <p>Bring clear updates into meetings.</p>
        </article>
    </div>

    <section class="home-section" aria-labelledby="features-title">
        <div class="section-heading">
            <p class="section-kicker">Built for follow-through</p>
            <h2 id="features-title">Key Features</h2>
            <p>
                Simple tools for keeping leadership work visible, organized, and ready for the next
                ward council conversation.
            </p>
        </div>

        <div class="feature-grid">
            <article class="feature-card">
                <span class="feature-icon feature-icon-clipboard" aria-hidden="true"></span>
                <h3>Track Callings</h3>
                <p>Keep calling status, organization, assigned member, and follow-up needs easy to review.</p>
            </article>

            <article class="feature-card">
                <span class="feature-icon feature-icon-list" aria-hidden="true"></span>
                <h3>Manage Assignments</h3>
                <p>Record assignments, leaders, priorities, due dates, notes, and current progress.</p>
            </article>

            <article class="feature-card">
                <span class="feature-icon feature-icon-followup" aria-hidden="true"></span>
                <h3>Track Follow-Up</h3>
                <p>See what needs attention and help ward council members stay aligned on next steps.</p>
            </article>

            <article class="feature-card">
                <span class="feature-icon feature-icon-report" aria-hidden="true"></span>
                <h3>View Reports</h3>
                <p>Review open callings, overdue assignments, and other summaries for leadership meetings.</p>
            </article>
        </div>
    </section>

    <section class="home-section home-useful" aria-labelledby="useful-title">
        <div>
            <h2 id="useful-title">Why WardSync Is Useful</h2>
            <p>
                Church leadership work often moves through meetings, messages, notes, and quick
                hallway conversations. WardSync gives leaders one simple place to see what is open,
                who is helping, what needs follow-up, and what has already been completed.
            </p>
        </div>
    </section>

    <section class="home-section target-users" aria-labelledby="users-title">
        <h2 id="users-title">Who WardSync Is For</h2>

        <ul class="target-user-list">
            <li>Bishoprics and branch presidencies</li>
            <li>Clerks and executive secretaries</li>
            <li>Auxiliary presidencies</li>
            <li>Ward council members</li>
            <li>Approved read-only users</li>
        </ul>
    </section>
</div>


@code {

    private List<AssignmentItem> assignments = new();
    private List<Calling> callings = new();

    private int openAssignments;
    private int completedAssignments;
    private int overdueAssignments;
    private int openCallings;

    private bool ShowNotification { get; set; }
    private int PendingAssignments { get; set; }
    private int OverdueAssignments { get; set; }
    private int FollowUpsNeeded { get; set; }
    private int OpenCallings { get; set; }


    protected override async Task OnInitializedAsync()
    {
        assignments = await Service.GetAssignmentsAsync();
        callings = await Service.GetCallingsAsync();

        openAssignments = assignments.Count(a => a.Status == "Open");
        completedAssignments = assignments.Count(a => a.Status == "Completed");
        overdueAssignments = assignments.Count(a =>
            a.DueDate < DateTime.Today &&
            a.Status != "Completed");

        openCallings = callings.Count(c => c.Status == "Open");

        PendingAssignments = openAssignments;
        OverdueAssignments = overdueAssignments;
        OpenCallings = openCallings;
        FollowUpsNeeded = 0;

        ShowNotification =
            PendingAssignments > 0 ||
            OverdueAssignments > 0 ||
            OpenCallings > 0 ||
            FollowUpsNeeded > 0;
    }

    private async Task CloseNotification()
    {
        ShowNotification = false;
        await InvokeAsync(StateHasChanged);
    }
}

<AuthorizeView Roles="Admin">
    <Authorized>
        @if (ShowNotification)
        {
            <div class="modal-overlay">
                <div class="modal-box">
                    <h3>Task Reminder</h3>

                    <p>You currently have:</p>

                    <ul>
                        <li>@PendingAssignments pending assignments</li>
                        <li>@OverdueAssignments overdue assignments</li>
                        <li>@OpenCallings open callings</li>
                        <li>@FollowUpsNeeded follow-up items</li>
                    </ul>

                    <button class="btn btn-primary"
                            @onclick="() => ShowNotification = false">
                        OK
                    </button>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>