@page "/assignments"
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin,Leader")]
@inject WardSyncService Service

<h1>Manage Assignments</h1>

<div class="button-row">
    <a class="btn-primary" href="/assignments/create">
        Create Assignment
    </a>
</div>

<hr />

<div class="filter-row">
    <div class="search-box">
        <span class="search-icon">🔍</span>

        <InputText @bind-Value="searchText"
                   placeholder="Search assignments..." />
    </div>

    <InputSelect @bind-Value="statusFilter">
        <option value="">All Status</option>
        <option value="Open">Open</option>
        <option value="In Progress">In Progress</option>
        <option value="Completed">Completed</option>
    </InputSelect>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Leader</th>
            <th>Organization</th>
            <th>Due Date</th>
            <th>Priority</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var assignment in FilteredAssignments)
        {
            <tr>
                <td>@assignment.Title</td>
                <td>@assignment.AssignedLeader</td>
                <td>@assignment.Organization</td>
                <td>@assignment.DueDate.ToShortDateString()</td>
                <td>@assignment.Priority</td>
                <td>@assignment.Status</td>
                <td>
                    <a class="btn-view" href="/assignments/details/@assignment.Id">View</a>

                    <a class="btn-edit" href="/assignments/edit/@assignment.Id">Edit</a>

                    <button type="button"
                            class="btn-delete"
                            @onclick="() => ShowDeletePopup(assignment)">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (showDeleteConfirmation && assignmentToDelete is not null)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3>Delete Assignment</h3>

            <p>Are you sure you want to delete this assignment?</p>

            <p><strong>Title:</strong> @assignmentToDelete.Title</p>
            <p><strong>Assigned Leader:</strong> @assignmentToDelete.AssignedLeader</p>
            <p><strong>Organization:</strong> @assignmentToDelete.Organization</p>
            <p><strong>Due Date:</strong> @assignmentToDelete.DueDate.ToShortDateString()</p>
            <p><strong>Status:</strong> @assignmentToDelete.Status</p>

            <div class="button-row">
                <button type="button"
                        class="btn-delete"
                        @onclick="ConfirmDelete">
                    Yes, Delete
                </button>

                <button type="button"
                        class="btn-secondary"
                        @onclick="CancelDelete">
                    Cancel
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<AssignmentItem> assignments = new();

    private string searchText = string.Empty;

    private string statusFilter = string.Empty;

    private bool showDeleteConfirmation;

    private AssignmentItem? assignmentToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssignments();
    }

    private async Task LoadAssignments()
    {
        assignments = await Service.GetAssignmentsAsync();
    }

    private IEnumerable<AssignmentItem> FilteredAssignments
    {
        get
        {
            var query = assignments.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(a =>
                    a.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    a.AssignedLeader.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    a.Organization.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    a.Priority.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    a.Status.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(statusFilter))
            {
                query = query.Where(a => a.Status == statusFilter);
            }

            return query.OrderBy(a => a.DueDate);
        }
    }

    private void ShowDeletePopup(AssignmentItem assignment)
    {
        assignmentToDelete = assignment;
        showDeleteConfirmation = true;
    }

    private async Task ConfirmDelete()
    {
        if (assignmentToDelete is not null)
        {
            await Service.DeleteAssignmentAsync(assignmentToDelete.Id);

            showDeleteConfirmation = false;
            assignmentToDelete = null;

            await LoadAssignments();
        }
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        assignmentToDelete = null;
    }
}